{
  "layer": "top",
  "position": "top",
  "mod": "dock",
  "exclusive": true,
  "passthrough": false,
  "gtk-layer-shell": true,
  "height": 0,
  "margin-top": 10,
  "margin-left": 15,
  "margin-right": 15,
  "spacing": 4,

  "modules-left": ["custom/apps", "custom/tools", "clock", "wlr/taskbar", "hyprland/window"],
  "custom/tools": {
    "format": "­¤øĀ’ĖÅ",
    "tooltip": "Ricing Tools",
    "on-click": "~/.config/hypr/scripts/ricing-tools.sh"
  },
  "custom/music-prev": {
    "format": "{}",
    "exec": "echo ¾░Æ«",
    "interval": 2,
    "tooltip": false,
    "on-click": "playerctl previous",
    "exec-if": "playerctl status",
  },

  "custom/music": {
    "format": "{}",
    "escape": true,
    "return-type": "json",
    "exec": "waybar-module-music --marquee --title-width 20 --stopped-label \"No Music\"",
    "on-click-right": "spotify",
    "on-click": "playerctl play-pause",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous",
  },

  "custom/music-next": {
    "interval": 2,
    "format": "{}",
    "exec": "echo ¾░ÆŁ",
    "tooltip": false,
    "on-click": "playerctl next",
    "exec-if": "playerctl status",
  },
  "modules-center": ["hyprland/workspaces"],
  "modules-right": [
    "tray",
    "custom/updates",
    "cpu",
    "memory",
    "disk",
    "temperature",
    "custom/music-prev",
    "custom/music",
    "custom/music-next",
    "pulseaudio",
    "network",
    "bluetooth",
    "battery",
    "custom/notification",
    "custom/power",
  ],

  "bluetooth": {
    "format": "’Ŗō",
    "format-disabled": "¾░é▓",
    "format-connected": "¾░é▒",
    "tooltip-format": "{status}",
    "tooltip-format-connected": "{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}",
    "on-click": "blueman-manager"
  },

  "custom/updates": {
    "format": "{}",
    "escape": true,
    "return-type": "json",
    "exec": "~/.config/hypr/scripts/updates.sh",
    "restart-interval": 60,
    "on-click": "~/.config/hypr/settings/installupdates.sh",
    "tooltip": true,
  },

  "custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "’éó<span foreground='red'><sup>’æä</sup></span>",
      "none": "’éó",
      "dnd-notification": "’ćĘ<span foreground='red'><sup>’æä</sup></span>",
      "dnd-none": "’ćĘ",
      "inhibited-notification": "’éó<span foreground='red'><sup>’æä</sup></span>",
      "inhibited-none": "’éó",
      "dnd-inhibited-notification": "’ćĘ<span foreground='red'><sup>’æä</sup></span>",
      "dnd-inhibited-none": "’ćĘ",
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true,
  },

  "custom/apps": {
    "format": "’īā",
    "tooltip": false,
    "on-click": "~/.config/hypr/scripts/launcher.sh",
  },

  "clock": {
    "format": "{:%H:%M | %a, %d %b}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "format": {
        "months": "<span color='#ffffff'><b>{}</b></span>",
        "days": "<span color='#cccccc'>{}</span>",
        "weeks": "<span color='#99ffdd'>W{}</span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff5f56'><b><u>{}</u></b></span>",
      },
    },
    "on-click": "flatpak run com.ml4w.calendar",
    "actions": {
      "on-click-right": "mode",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down",
    },
  },

  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": 18,
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-middle": "close",
  },

  "hyprland/window": {
    "format": "{}",
    "max-length": 25,
    "separate-outputs": true,
    "rewrite": {
      "": "",
      "(.+)": " $1 ",
    },
  },

  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "on-click": "activate",
    "format": "{icon}",
    "persistent-workspaces": {
      "*": 5,
    },
    "format-icons": {
      "active": "¾░«»",
      "default": "¾░ŖĀ",
      "urgent": "’ü¬",
      "persistent": "¾░ŖĀ",
    },
  },

  "tray": {
    "icon-size": 16,
    "spacing": 10,
  },

  "cpu": {
    "format": "’Æ╝ {usage}%",
    "interval": 2,
    "on-click": "~/.config/hypr/settings/system-monitor.sh",
  },

  "memory": {
    "format": "’öĖ {}%",
    "interval": 2,
    "on-click": "~/.config/hypr/settings/system-monitor.sh",
  },

  "disk": {
    "interval": 30,
    "format": "¾░ŗŖ {percentage_used}%",
    "path": "/",
    "tooltip-format": "{used} used / {total} total ({percentage_free}% free)",
    "on-click": "~/.config/hypr/settings/system-monitor.sh",
  },

  "temperature": {
    "thermal-node": "/sys/class/thermal/thermal_zone0",
    "critical-threshold": 80,
    "format": "{icon} {temperatureC}┬░C",
    "format-icons": ["’ŗŗ", "’ŗŖ", "’ŗē", "’ŗł", "’ŗć"],
  },

  "network": {
    "format-wifi": "’ć½",
    "format-ethernet": "¾░łĆ",
    "format-disconnected": "¾░ż«",
    "tooltip-format": "{essid} {signalStrength}%",
    "on-click": "~/.config/hypr/scripts/wifi-menu.sh",
    "on-click-right": "~/.config/hypr/settings/networkmanager.sh",
  },

  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-muted": "¾░Ø¤",
    "format-icons": {
      "default": ["’Ć”", "’Ć¦", "’Ć©"],
    },
    "on-click": "~/.config/hypr/scripts/volume-menu.sh",
    "on-click-right": "pavucontrol",
    "on-scroll-up": "swayosd-client --output-volume raise",
    "on-scroll-down": "swayosd-client --output-volume lower",
  },

  "battery": {
    "format": "{icon} {capacity}%",
    "format-icons": ["’ēä", "’ēā", "’ēé", "’ēü", "’ēĆ"],
  },

  "custom/power": {
    "format": "ŌÅ╗",
    "tooltip": false,
    "on-click": "wlogout -b 6",
  },
}
